# FloraIntellect — variables de entorno
# Copiá este archivo como .env y completá los valores.

# Plant.id — identificación por foto (REQUERIDO para /identificar)
# Registro gratis: https://plant.id/api (100 identificaciones/mes)
PLANTID_KEY=tu_key_de_plantid_aqui

# Motor de chat (elegí UNO)
# Opción A: Groq (gratis, sin tarjeta) — recomendado
# Registro: https://console.groq.com → API Keys
LLM_PROVIDER=groq
GROQ_API_KEY=tu_key_de_groq_aqui
LLM_MODEL=llama-3.3-70b-versatile

# Opción B: Anthropic Claude (de pago, mejor calidad)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-tu_key_aqui
# LLM_MODEL=claude-sonnet-4-20250514

# Pixabay — fotos de referencia (opcional)
# Registro: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Server
PORT=3030
